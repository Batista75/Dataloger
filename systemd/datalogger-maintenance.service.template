[Unit]
Description=Datalogueur EM06 daily DB backup and raw retention purge
After=network-online.target datalogger.service
Wants=network-online.target

[Service]
Type=oneshot
User=__APP_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/.venv/bin/python3 __APP_DIR__/tools/run_daily_maintenance.py

[Install]
WantedBy=multi-user.target
