APP_HOST=0.0.0.0
APP_PORT=8000
POLL_SECONDS=3
# Mettre a 1 seulement si la sonde C1 est encore inversee cote Refoss (sans correction materielle).
C1_POWER_INVERT=0

# Graphe puissance du jour (periode 27-29/06/2026 = donnees douteuses avant 14h locale)
CHART_SLOT_MINUTES=15
CHART_UNRELIABLE_FROM=2026-06-27
CHART_UNRELIABLE_UNTIL=2026-06-29
CHART_UNRELIABLE_LOCAL_START=14:00
CHART_MIN_SAMPLES_PER_SLOT=5
# 1 = marquer quality_flag=3 au demarrage (une fois apres deploy, puis remettre a 0)
CHART_MARK_SUSPECT_ON_STARTUP=0
DB_PATH=data/measurements.db

# Rétention brut 3 s (power_slots et imports journaliers conserves)
RAW_RETENTION_DAYS=90
BACKUP_DIR=data/backups
BACKUP_KEEP_COUNT=14
# 1 = timer systemd backup+purge quotidien (02:30)
MAINTENANCE_ENABLED=1

# EM06P Open API modes used by this project:
# - refoss_local_socket: HTTP JSON-RPC 2.0 (recommended for local polling)
# - mqtt_json: MQTT subscription from broker
# - meross_local_post/http_json: compatibility modes
# - mock: test mode
EM06_MODE=refoss_local_socket

EM06_HTTP_URL=http://192.168.1.119
EM06_TIMEOUT_SECONDS=5
EM06_HTTP_USERNAME=admin
EM06_HTTP_PASSWORD=change-me
# Cle locale du device Meross (POST /config). Visible dans l'app Refoss : appareil > parametres > About > Key
EM06_MEROSS_KEY=
EM06_NAMESPACE=Appliance.Control.Electricity

EM06_MQTT_HOST=
EM06_MQTT_PORT=1883
EM06_MQTT_TOPIC=
EM06_MQTT_CLIENT_ID=datalogger-em06p
EM06_MQTT_USERNAME=
EM06_MQTT_PASSWORD=

# Optional EM06P webhook endpoint(s) configured in device Web UI
# (the collector does not consume webhooks directly).
# EM06_WEBHOOK_URL=https://your-server.example/em06p/webhook
# EM06_WEBHOOK_AUTH_TOKEN=change-me

# Tuya temperature extension (TinyTuya)
TUYA_ENABLED=0
TUYA_POLL_SECONDS=30
TUYA_TARGET_MACS=2E:82:1D:8A:64:17
TUYA_TINYTUYA_DEVICE_ID=
TUYA_TINYTUYA_LOCAL_KEY=
TUYA_TINYTUYA_IP=
TUYA_TINYTUYA_VERSION=3.3
TUYA_LATEST_JSON_PATH=data/tuya_temperature_latest.json
TUYA_HISTORY_CSV_PATH=data/tuya_temperature_history.csv
TUYA_WATCH_SECONDS=0
TUYA_MIN_DELTA_C=0.1
TUYA_CAPTURE_RETRIES=3
TUYA_CAPTURE_RETRY_DELAY_SECONDS=1.5
TUYA_CAPTURE_MODE=local
TUYA_CLOUD_API_KEY=
TUYA_CLOUD_API_SECRET=
TUYA_CLOUD_API_REGION=eu

REFOSS_PORT=9989
REFOSS_DEVICE_IP=192.168.1.119
REFOSS_ALLOW_SIMULATED_FALLBACK=0

# Export journalier Power Monitor Day Data (timer systemd 00:05)
EM06_DAY_DATA_EXPORT_ENABLED=0
EM06_DAY_DATA_BASE_CSV=data/refoss_history/Power Monitor Day Data - Smart Energy Monitor - 20260627.csv
EM06_DAY_DATA_OUTPUT_DIR=exports
EM06_DAY_DATA_EXTENSION_OUT=exports/Power Monitor Day Data - raspberry.csv
EM06_DAY_DATA_COMBINED_OUT=exports/Power Monitor Day Data - combined.csv
EM06_DAY_DATA_FROM_DATE=2026-06-28

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
